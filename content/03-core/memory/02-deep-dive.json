<h2>流式上下文净化</h2>

<pre><code class="language-python">class StreamingContextScrubber:
    \"\"\"处理流式文本中可能 split 的 memory-context spans\"\"\"
    # 状态机：_in_span + _buf 追踪 chunk 边界上的标签泄漏

def build_memory_context_block(raw_context: str) -> str:
    return (
        \"<memory-context>\\n\"
        \"[System note: The following is recalled memory context, \"
        \"NOT new user input. Treat as authoritative reference data — ...]\\n\\n\"
        f\"{clean}\\n\"
        \"</memory-context>\"
    )</code></pre>

<h2>FTS5 全文搜索</h2>

<h3>双 FTS5 表设计</h3>

<pre><code class="language-sql">-- 标准 unicode61 tokenizer for 拉丁语言
CREATE VIRTUAL TABLE messages_fts USING fts5(content);
CREATE TRIGGER messages_fts_insert AFTER INSERT ON messages BEGIN ... END;

-- Trigram tokenizer for CJK 子串搜索
CREATE VIRTUAL TABLE messages_fts_trigram USING fts5(
    content, tokenize='trigram'
);</code></pre>

