<h2>MemoryProvider ABC 接口</h2>

<pre><code class="language-python">class MemoryProvider(ABC):
    # 生命周期
    def is_available(self) -> bool
    def initialize(self, session_id, **kwargs)
    def shutdown(self) -> None

    # 记忆操作
    def system_prompt_block() -> str           # 静态系统提示
    def prefetch(query, session_id) -> str     # 召回相关上下文
    def queue_prefetch(query, session_id)      # 后台预取
    def sync_turn(user, assistant, session_id) # 持久化 turn

    # 工具
    def get_tool_schemas() -> list[dict]       # 暴露给模型的工具
    def handle_tool_call(tool_name, args)      # 分发工具调用

    # 钩子（可选）
    def on_turn_start(turn, message)
    def on_session_end(messages)
    def on_session_switch(new_session_id, parent_session_id, reset)
    def on_pre_compress(messages)
    def on_memory_write(action, target, content, metadata)
    def on_delegation(task, result, child_session_id)</code></pre>

<h2>内置 MemoryStore 设计</h2>

<h3>双重状态机制</h3>

<pre><code class="language-python">class MemoryStore:
    # 冻结快照 - session 期间不变，确保前缀缓存命中
    self._system_prompt_snapshot: Dict[str, str] = {
        "memory": "",
        "user": ""
    }

    # 实时状态 - 通过 tool 调用变更，即时持久化
    self.memory_entries: List[str] = []
    self.user_entries: List[str] = []</code></pre>

